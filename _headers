<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Ma Visite 3D</title>
    <style>
        body { margin: 0; padding: 0; overflow: hidden; background-color: #000; }
        canvas { display: block; width: 100vw; height: 100vh; }
    </style>
    <!-- Chargement du lecteur 3D -->
    <script type="importmap">
    {
        "imports": {
            "three": "https://unpkg.com/three@0.157.0/build/three.module.js",
            "@mkkellogg/gaussian-splats-3d": "https://unpkg.com/@mkkellogg/gaussian-splats-3d/build/gaussian-splats-3d.module.js"
        }
    }
    </script>
</head>
<body>
    <script type="module">
        import * as GaussianSplats3D from '@mkkellogg/gaussian-splats-3d';

        const viewer = new GaussianSplats3D.Viewer({
            'initialCameraPosition': [0, 0, 5],
            'initialCameraLookAt': [0, 0, 0]
        });
        
        // C'est ici qu'on appelle votre fichier ! (Corrigé avec un petit m)
        viewer.addSplatScene('./model.splat', {
            'progressiveLoad': true
        })
        .then(() => {
            viewer.start();
        });
    </script>
</body>
</html>
